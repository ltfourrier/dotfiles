# Import the "catppuccin" theme.
import:
  - <%= File.join(destination, 'catppuccin.yml') %>

# I believe that this enables true color (could be supported by default, though).
env:
  TERM: xterm-256color

window:
  startup_mode: Fullscreen
  ime_input: false
  option_as_alt: Both
font:
  size: 10.0
  normal:
    family: MesloLGS Nerd Font
mouse:
  hide_when_typing: true
